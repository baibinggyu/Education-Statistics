# 数据库
education_statistics_passwd=edu123456
education_statistics_db_host=127.0.0.1
education_statistics_db_port=3306
education_statistics_db_name=edu_server_database
education_statistics_db_user=edu_user

# JWT
education_statistics_secret_key=CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_CHARS

# 服务器
education_statistics_server_ip=your.server.ip
edu_server_host=127.0.0.1
edu_server_port=55555

# AI 代理（仅服务器配置，客户端和 public 仓库不要放真实 key）
ANTHROPIC_AUTH_TOKEN=sk-your-deepseek-key
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL=deepseek-v4-pro
AI_PROXY_TIMEOUT_SECONDS=60

